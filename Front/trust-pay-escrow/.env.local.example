# Trust Pay Escrow env config
# Copy this file to .env.local and fill in your values

# Required – get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Smart Contract addresses (deploy your own or use the demo zero address)
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Chain ID: 11155111 = Sepolia, 80001 = Mumbai, 1 = Mainnet
NEXT_PUBLIC_CHAIN_ID=11155111

# Infura RPC (optional – wagmi uses public RPCs by default)
NEXT_PUBLIC_INFURA_ID=your_infura_id_here

# web3.storage token for IPFS uploads (optional – app uses mock CIDs without it)
NEXT_PUBLIC_WEB3_STORAGE_TOKEN=your_token_here
